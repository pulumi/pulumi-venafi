{
    "compilerOptions": {
        // Output
        "outDir": "bin",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "stripInternal": true,
        // Environment
        "target": "ES2022",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "moduleDetection": "force",
        "types": ["node"],
        // Type Checking
        "strict": true,
        "noFallthroughCasesInSwitch": true,
        "noImplicitReturns": true,
        "skipLibCheck": true
    },
    "files": [
        "certificate.ts",
        "cloudKeystoreInstallation.ts",
        "config/index.ts",
        "config/vars.ts",
        "getCloudKeystore.ts",
        "getCloudProvider.ts",
        "index.ts",
        "policy.ts",
        "provider.ts",
        "sshCertificate.ts",
        "sshConfig.ts",
        "utilities.ts"
    ]
}
